# RePen India Backend Configuration
# Copy this file to .env and fill in your actual values

# PostgreSQL Database
DATABASE_URL=postgresql://repenuser:your_secure_password@localhost:5432/rependb
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# JWT Authentication
# IMPORTANT: Must be at least 32 characters!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# App — set to "production" in deployment
APP_ENV=development
APP_DEBUG=false
